<?xml version="1.0" encoding="utf-8"?>
<window>
    <ama_actor_terminal x="102" y="0" width="1024" height="768">
        <background x="0" y="0" width="280" height="768">
            <texture>ui\ui_hud_ama_terminal_actor</texture>
            <texture_rect x="372" y="128" width="280" height="768"/>
            
            <actor_status_text x="98" y="43" width="150" height="20">
                <text font="letterica16" align="l">ACTOR STATUS</text>
            </actor_status_text>

            <blood_vol_label x="25" y="73" width="100" height="20">
                <text font="letterica16" align="l">BLOOD VOL</text>
            </blood_vol_label>

            <pain_level_label x="25" y="104" width="100" height="20">
                <text font="letterica16" align="l">PAIN LEVEL</text>
            </pain_level_label>

            <total_loss_val x="23" y="135" width="230" height="20">
                <text font="letterica16" align="l">TOTAL BLOOD LOSS: 0 mL/s</text>
            </total_loss_val>

            <active_bleeds_val x="92" y="172" width="230" height="20">
                <text font="letterica16" align="l">ACTIVE BLEEDS: 0</text>
            </active_bleeds_val>

            <flesh_wounds_val x="92" y="333" width="230" height="20">
                <text font="letterica16" align="l">FLESH WOUNDS: 0</text>
            </flesh_wounds_val>

            <bone_fractures_val x="92" y="494" width="230" height="20">
                <text font="letterica16" align="l">BONE FRACTURES: 0</text>
            </bone_fractures_val>

            <sepsis_val x="16" y="645" width="230" height="20">
                <text font="letterica16" align="l">SEPSIS: CLEAN</text>
            </sepsis_val>

            <blood_vol_bar x="25" y="88" width="230" height="11" horz="1" min="0" max="1" pos="0">
                <background stretch="1"><texture>ui_ama_terminal_bar_bg</texture></background>
                <progress stretch="1"><texture>ui_ama_blood_fill</texture></progress>
            </blood_vol_bar>

            <pain_level_bar x="25" y="119" width="230" height="11" horz="1" min="0" max="1" pos="0">
                <background stretch="1"><texture>ui_ama_terminal_bar_bg</texture></background>
                <progress stretch="1"><texture>ui_ama_pain_fill</texture></progress>
            </pain_level_bar>
        </background>
    </ama_actor_terminal>

    <wound_list_item x="0" y="0" width="230" height="24">
        <wound_rate_text x="0" y="4" width="140" height="20">
            <text font="letterica16" r="255" g="255" b="255" a="255" align="l"/>
        </wound_rate_text>
        
        <wound_type_text x="150" y="4" width="80" height="20">
            <text font="letterica16" r="255" g="255" b="255" a="255" align="r"/>
        </wound_type_text>
    </wound_list_item>
</window>