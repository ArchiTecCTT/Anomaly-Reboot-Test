function reset_hit_state()
    hit_state.traversed = {}
    hit_state.iterations = 0
    hit_state.remaining_power = 0
    hit_state.remaining_pen = 0
end

-- Sequential Bullet Hit Pain Tracker
local bhp_seq = 1
local function play_sequential_bhp()
    utils_obj.play_sound("actor\\bullet_hit_pain_" .. bhp_seq)
    bhp_seq = bhp_seq + 1
    if bhp_seq > 3 then bhp_seq = 1 end
end

