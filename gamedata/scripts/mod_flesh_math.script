-- ==========================================================
-- WOUND GENERATION & ANATOMY MATRIX
-- ==========================================================
local function acquire_wound(w_type, bleed, organ, limb, lethality)
    return { type = w_type, bleed_rate = bleed, organ = organ, limb = limb or "", lethality = lethality or 0 }
end

local TISSUE_PROPERTIES = {
    ["brain"]          = { thickness = 150, hardness = 0.20, base_bleed = 30.0, death_rating = 1.0 },
    ["lungs"]          = { thickness = 200, hardness = 0.05, base_bleed = 25.0, death_rating = 0.8 },
    ["heart"]          = { thickness = 115, hardness = 0.25, base_bleed = 80.0, death_rating = 1.0 },
    ["liver"]          = { thickness = 140, hardness = 0.30, base_bleed = 45.0, death_rating = 0.6 },
    ["gi_tract"]       = { thickness = 230, hardness = 0.15, base_bleed = 15.0, death_rating = 0.4 },
    ["skull"]          = { thickness = 10,  hardness = 0.85, base_bleed = 0.0,  death_rating = 0.0 },
    ["cervical_spine"] = { thickness = 24,  hardness = 0.65, base_bleed = 5.0,  death_rating = 1.0 },
    ["lumbar_spine"]   = { thickness = 45,  hardness = 0.65, base_bleed = 5.0,  death_rating = 1.0 },
    ["rib"]            = { thickness = 13,  hardness = 0.50, base_bleed = 2.0,  death_rating = 0.0 },
    ["ilium"]          = { thickness = 10,  hardness = 0.60, base_bleed = 30.0, death_rating = 0.2 },
