-- ==========================================================
-- TELEMETRY ENGINE (DEBUG FEED)
-- ==========================================================

local function log_telemetry(data)
    if not mod_directional_armor.AMA_DEBUG_MODE then return end
    
    log(string.format("[AMA BALLISTICS] ----------------------------------------------"))
    log(string.format("[TARGET]      : %s", data.target or "db.actor (SKY)"))
    log(string.format("[HIT BONE]    : %s (%s)", data.bone or "UNKNOWN", data.zone or "UNKNOWN"))
    log(string.format("[PROJECTILE]  : %s", data.ammo or "Mutant / Melee"))
    log(string.format("[KINETIC]     : Power: %.2f | Impulse: %.2f | k_ap: %.2f", data.power or 0, data.impulse or 0, data.kap or 0))
    log(string.format("[GEOMETRY]    : Angle: %.1f deg | Cos_Val: %.2f", data.angle or 0, data.cos_val or 0))
    
    if data.plate_sec then
        log(string.format("[PLATE]       : %s (%.1fmm @ %d%%) | Hardness: %.2f", data.plate_sec, data.nom_thick or 0, (data.cond or 0) * 100, data.hardness or 0))
        if data.soft_mm then
            log(string.format("[CALC]        : Eff_Thick: %.2fmm | soft_armor_mm: %.1fmm", data.eff_thick or 0, data.soft_mm))
        else
            log(string.format("[CALC]        : Eff_Thick: %.2fmm | Pen_Ratio: %.2f", data.eff_thick or 0, data.pen_ratio or 0))
        end
    else
        log(string.format("[PLATE]       : NONE"))
    end
    
    log(string.format("[RESULT]      : %s", data.phase or "UNKNOWN"))
    log(string.format("[FINAL DMG]   : %s", data.final_dmg_str or "N/A"))
    log(string.format("[--------------------------------------------------------------]"))
end

